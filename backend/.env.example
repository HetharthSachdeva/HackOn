# ============================================================================
# Application
# ============================================================================
APP_NAME="Quick-Commerce API"
APP_ENV="dev"               # dev | staging | prod
APP_DEBUG=true
API_V1_PREFIX="/api/v1"
LOG_LEVEL="INFO"            # DEBUG | INFO | WARNING | ERROR

# Comma-separated origins. Use "*" for any origin in dev.
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ============================================================================
# Supabase
# ----------------------------------------------------------------------------
# Find these in your Supabase project:
#   Project Settings > API           -> URL, anon key, service_role key
#   Project Settings > API > JWT     -> JWT secret (for token verification)
#   Project Settings > Database      -> Connection string (use POOLED, port 6543)
# ============================================================================
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOi..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# Modern Supabase projects use asymmetric JWT signing keys (ES256/RS256), and
# the server verifies tokens via the public JWKS endpoint:
#   <SUPABASE_URL>/auth/v1/.well-known/jwks.json
# Leave SUPABASE_JWT_SECRET empty in that case (the default).
# Set it ONLY if your project still uses the legacy HMAC-signed JWTs.
SUPABASE_JWT_SECRET=""

# Async SQLAlchemy URL. Use the POOLED connection (port 6543) for serverless-friendly behavior.
# Format: postgresql+asyncpg://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql+asyncpg://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# ============================================================================
# AI / LLM (Phase 3 — optional, all features have non-AI fallbacks)
# ============================================================================
LLM_PROVIDER="stub"         # stub | openai | azure | anthropic | gemini
LLM_API_KEY=""
LLM_MODEL=""

# Local embedding model used by Intent-to-Cart (matches the model used to
# populate the `embedding` column in qcommerce_products).
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# ============================================================================
# Redis  —  REQUIRED for WebSocket realtime + rate limiting
# ----------------------------------------------------------------------------
# WebSocket fan-out uses Redis pub/sub so the API can scale to multiple
# workers / replicas. The REST API works fine without Redis, but the
# /ws/* endpoints will close immediately with a structured error.
#
# Local dev (Docker Compose includes a Redis service):
#   REDIS_URL="redis://localhost:6379/0"
# Upstash / managed:
#   REDIS_URL="rediss://default:<password>@<region>.upstash.io:6379"
# ============================================================================
REDIS_URL=""
REDIS_NAMESPACE="qc"           # Prefix for all keys/channels we own

# ============================================================================
# Rate limiting (Redis-backed, fixed-window per IP per minute)
# ============================================================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=120

# ============================================================================
# Admin endpoints
# ----------------------------------------------------------------------------
# Static shared-secret. Send as `X-Admin-Token: <value>` header. Leave blank
# to disable the entire /api/v1/admin/* router.
# ============================================================================
ADMIN_TOKEN=""
